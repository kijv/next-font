{
  "name": "@next-font/workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "test": "vp test",
    "lint": "vp lint --deny-warnings --report-unused-disable-directives --type-aware",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "version": "changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "publint": "^0.3.18",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.32.0"
}
