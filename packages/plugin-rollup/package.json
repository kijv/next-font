{
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "name": "rollup-plugin-next-font",
  "version": "0.0.0",
  "keywords": [
    "rollup-plugin"
  ],
  "license": "BSD-2-Clause",
  "author": {
    "name": "kijv",
    "email": "kijv999@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kijv/next-font.git",
    "directory": "packages/plugin-rollup"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack --minify",
    "dev": "vp pack --watch --sourcemap"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@node-rs/xxhash": "^1.7.6",
    "fontkit": "^2.0.4",
    "oxc-parser": "^0.116.0"
  },
  "devDependencies": {
    "@next-font/common": "workspace:*",
    "@rolldown/pluginutils": "1.0.0-rc.9",
    "esrap": "^2.2.3",
    "rolldown-plugin-next-font": "workspace:*",
    "rollxxx": "workspace:^"
  },
  "peerDependencies": {
    "rollup": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^7.0.0"
    },
    "rolldown": {
      "type": "incompatible",
      "reason": "Use the vite plugin instead"
    },
    "rollup": {
      "type": "compatible",
      "versions": "^4.0.0"
    }
  }
}
