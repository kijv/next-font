{
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "name": "vite-plugin-next-font",
  "version": "1.0.0-beta.0",
  "keywords": [
    "vite-plugin"
  ],
  "license": "BSD-2-Clause",
  "author": {
    "name": "kijv",
    "email": "kijv999@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kijv/next-font.git",
    "directory": "packages/plugin-vite"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@node-rs/xxhash": "^1.7.6",
    "fontkit": "^2.0.4",
    "oxc-parser": "^0.116.0"
  },
  "devDependencies": {
    "@next-font/common": "workspace:*",
    "@rolldown/pluginutils": "1.0.0-rc.9",
    "esrap": "^2.2.3"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^8.0.0"
    },
    "rollup": {
      "type": "incompatible",
      "reason": "Vite 8 does not use Rollup"
    },
    "rolldown": {
      "type": "compatible",
      "versions": "^1.0.0-rc.9"
    }
  }
}
